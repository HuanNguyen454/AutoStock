{
  "App": {
    "UseHttpsRedirection": true,
    "ApplyMigrationsOnStartup": true,
    "SeedSystemData": true,
    "SeedDemoData": true
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\MyLocalDB;Database=AsmWmsDb;Trusted_Connection=True;TrustServerCertificate=True"
  },
  "Jwt": {
    "Issuer": "ASM.Api",
    "Audience": "ASM.Clients",
    "SigningKey": "AsmJwtSigningKey1234567890!ChangeMe",
    "AccessTokenMinutes": 120,
    "RefreshTokenDays": 14
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
