@model string
@{
    ViewData["Title"] = "Access Denied";
}

<div class="panel-card p-4 p-md-5 mx-auto" style="width:min(520px, 92vw);">
    <p class="text-uppercase text-muted small mb-2">ASM Access</p>
    <h1 class="h3 mb-3">You do not have permission to open that page</h1>
    <p class="text-muted mb-4">
        Your account signed in successfully, but the destination page is not available for your role.
    </p>

    @if (!string.IsNullOrWhiteSpace(Model))
    {
        <div class="alert alert-warning small mb-4">
            Requested page: <code>@Model</code>
        </div>
    }

    <div class="d-flex gap-3 flex-wrap">
        <a asp-controller="Dashboard" asp-action="Index" asp-area="" class="btn btn-dark">Go to Portal</a>
        <a asp-controller="Admin" asp-action="Index" asp-area="" class="btn btn-outline-dark">Go to Admin</a>
        <a asp-controller="Tasks" asp-action="Index" asp-area="Staff" class="btn btn-outline-secondary">Go to Staff Tasks</a>
    </div>
</div>
