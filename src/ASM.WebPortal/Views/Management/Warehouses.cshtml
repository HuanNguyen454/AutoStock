@model WarehousesPageViewModel
@{
    ViewData["Title"] = "Warehouses";
}
@if (TempData["SuccessMessage"] is string successMessage)
{
    <div class="alert alert-success">@successMessage</div>
}
@if (TempData["ErrorMessage"] is string errorMessage)
{
    <div class="alert alert-danger">@errorMessage</div>
}

<div class="row g-4">
    <div class="col-lg-4">
        <div class="panel-card p-4">
            <h1 class="h4">Create Warehouse</h1>
            <form asp-action="CreateWarehouse" method="post" class="form-grid">
                <input asp-for="Name" class="form-control" placeholder="Name" />
                <input asp-for="Code" class="form-control" placeholder="Code" />
                <input asp-for="Address" class="form-control" placeholder="Address" />
                <button class="btn btn-dark">Save Warehouse</button>
            </form>
        </div>
    </div>
    <div class="col-lg-8">
        <div class="panel-card p-4">
            <table class="table align-middle">
                <thead><tr><th>Warehouse</th><th>QR</th><th>Delete</th></tr></thead>
                <tbody>
                @foreach (var item in Model.Warehouses)
                {
                    <tr>
                        <td>
                            <form asp-action="UpdateWarehouse" method="post" class="warehouse-edit-row">
                                <input type="hidden" name="warehouseId" value="@item.Id" />
                                <input name="name" class="form-control" value="@item.Name" aria-label="Warehouse name" />
                                <input name="code" class="form-control" value="@item.Code" aria-label="Warehouse code" />
                                <input name="address" class="form-control" value="@item.Address" aria-label="Warehouse address" />
                                <button class="btn btn-sm btn-dark">Save</button>
                            </form>
                        </td>
                        <td>
                            @if (Model.QrCodes.TryGetValue(item.Id, out var qr))
                            {
                                <a class="btn btn-sm btn-outline-dark" asp-action="DownloadQr" asp-controller="Management" asp-route-qrId="@qr.Id">Download QR</a>
                            }
                        </td>
                        <td>
                            <form asp-action="DeleteWarehouse" method="post" onsubmit="return confirm('Delete this warehouse?');">
                                <input type="hidden" name="warehouseId" value="@item.Id" />
                                <button class="btn btn-sm btn-outline-danger">Delete</button>
                            </form>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>
