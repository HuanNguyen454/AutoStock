@model ProductsPageViewModel
@{
    ViewData["Title"] = "Products";
}

<section class="panel-card p-4 mb-4">
    <div class="dashboard-section-head">
        <div>
            <div class="dashboard-section-title">Product filters and location search</div>
            <div class="dashboard-section-subtitle">Search by SKU, name, description, or category inside the current tenant.</div>
        </div>
    </div>

    <form asp-action="Products" method="get" class="row g-3 align-items-end">
        <div class="col-lg-5">
            <label class="form-label" for="product-location-keyword">Keyword</label>
            <input
                id="product-location-keyword"
                name="keyword"
                value="@Model.Keyword"
                class="form-control"
                placeholder="Enter SKU or product name" />
        </div>
        <div class="col-lg-4">
            <label class="form-label" for="product-category-filter">Category</label>
            <select id="product-category-filter" name="categoryId" class="form-select">
                <option value="">All categories</option>
                @foreach (var category in Model.Categories)
                {
                    <option value="@category.Id" selected="@(Model.CategoryId == category.Id)">
                        @category.Name (@category.Code)
                    </option>
                }
            </select>
        </div>
        <div class="col-lg-3 d-flex gap-2">
            <button class="btn btn-dark flex-fill">Filter</button>
            @if (Model.HasSearched)
            {
                <a class="btn btn-outline-secondary" asp-action="Products">Clear</a>
            }
        </div>
    </form>

    @if (Model.HasSearched)
    {
        <div class="border-top pt-4 mt-4">
            @if (Model.LocationResults.Any())
            {
                @if (Model.WarehouseMaps.Any())
                {
                    <div class="product-map-stack mb-4">
                        @foreach (var warehouseMap in Model.WarehouseMaps)
                        {
                            <section class="product-map-panel">
                                <div class="product-map-head">
                                    <div>
                                        <div class="product-map-kicker">Warehouse grid</div>
                                        <h2 class="product-map-title">@warehouseMap.WarehouseName</h2>
                                        <div class="product-map-subtitle">@warehouseMap.WarehouseCode</div>
                                    </div>
                                    <div class="product-map-legend">
                                        <span><i class="product-map-dot product-map-dot-hit"></i> Found</span>
                                        <span><i class="product-map-dot product-map-dot-occupied"></i> Occupied</span>
                                        <span><i class="product-map-dot product-map-dot-empty"></i> Empty</span>
                                    </div>
                                </div>

                                @if (warehouseMap.RouteSummaries.Any())
                                {
                                    <div class="product-route-list">
                                        @foreach (var route in warehouseMap.RouteSummaries)
                                        {
                                            <div class="product-route-pill">
                                                <span class="product-route-start">Start</span>
                                                <span class="product-route-arrow">-></span>
                                                <span>@route</span>
                                            </div>
                                        }
                                    </div>
                                }

                                <div class="product-map-area-grid">
                                    @foreach (var area in warehouseMap.Areas)
                                    {
                                        <article class="product-map-area @(area.HighlightedSlotCount > 0 ? "is-active" : string.Empty)">
                                            <div class="product-map-area-head">
                                                <div>
                                                    <div class="product-map-label">Area</div>
                                                    <div class="product-map-area-name">@area.Name</div>
                                                </div>
                                                <span class="product-map-count">@area.HighlightedSlotCount found</span>
                                            </div>

                                            <div class="product-map-rack-stack">
                                                @foreach (var rack in area.Racks)
                                                {
                                                    <div class="product-map-rack-row">
                                                        <div class="product-map-rack-name">@rack.Name</div>
                                                        <div class="product-map-slot-grid">
                                                            @foreach (var slot in rack.Slots)
                                                            {
                                                                var slotClass = slot.HasMatch
                                                                    ? "is-match"
                                                                    : slot.IsOccupied ? "is-occupied" : "is-empty";

                                                                <div class="product-map-slot @slotClass" title="@slot.MatchSummary @slot.QuantitySummary @slot.Note">
                                                                    <div class="product-map-slot-name">@slot.Name</div>
                                                                    @if (slot.HasMatch)
                                                                    {
                                                                        <div class="product-map-slot-product">@slot.MatchSummary</div>
                                                                        <div class="product-map-slot-meta">@slot.QuantitySummary</div>
                                                                        <div class="product-map-slot-meta">@slot.Note</div>
                                                                    }
                                                                    else
                                                                    {
                                                                        <div class="product-map-slot-meta">@(slot.IsOccupied ? "Occupied" : "Empty")</div>
                                                                    }
                                                                </div>
                                                            }
                                                        </div>
                                                    </div>
                                                }
                                            </div>
                                        </article>
                                    }
                                </div>
                            </section>
                        }
                    </div>
                }
                else
                {
                    <div class="layout-inline-empty mb-4">Matching products were found, but none of them are currently assigned to a slot.</div>
                }

                <div class="table-responsive">
                    <table class="table align-middle">
                        <thead>
                            <tr>
                                <th>SKU</th>
                                <th>Product</th>
                                <th>Category</th>
                                <th>Lot</th>
                                <th>Expiry</th>
                                <th>Qty</th>
                                <th>Pallet</th>
                                <th>Status</th>
                                <th>Warehouse</th>
                                <th>Area</th>
                                <th>Rack</th>
                                <th>Slot</th>
                                <th>Full location</th>
                                <th>Note</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.LocationResults)
                            {
                                <tr>
                                    <td><span class="fw-semibold">@item.Sku</span></td>
                                    <td>@item.ProductName</td>
                                    <td>@(item.CategoryName ?? "-")</td>
                                    <td>@(item.LotNumber ?? "-")</td>
                                    <td>@(item.ExpiryDate?.ToString("yyyy-MM-dd") ?? "-")</td>
                                    <td>@(item.InventoryItemId.HasValue ? item.Quantity : "-")</td>
                                    <td>@(item.PalletCode ?? "-")</td>
                                    <td>@(item.PalletStatus ?? "-")</td>
                                    <td>@(item.WarehouseName ?? "-")</td>
                                    <td>@(item.AreaName ?? "-")</td>
                                    <td>@(item.RackName ?? "-")</td>
                                    <td>@(item.SlotName ?? "-")</td>
                                    <td>
                                        @if (string.IsNullOrWhiteSpace(item.LocationPath))
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                        else
                                        {
                                            <span>@item.LocationPath</span>
                                        }
                                    </td>
                                    <td>@(item.Note ?? "-")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="layout-empty-state">No matching products were found.</div>
            }
        </div>
    }
</section>

<div class="row g-4">
    <div class="col-lg-4">
        <div class="panel-card p-4 mb-4">
            <div class="dashboard-section-title mb-3">Add Category</div>
            <form asp-action="CreateCategory" method="post" class="form-grid">
                <input asp-for="CategoryCode" class="form-control" placeholder="Code" />
                <input asp-for="CategoryName" class="form-control" placeholder="Name" />
                <textarea asp-for="CategoryDescription" class="form-control" placeholder="Description"></textarea>
                <button class="btn btn-outline-dark">Save Category</button>
            </form>
        </div>

        <div class="panel-card p-4">
            <div class="dashboard-section-title mb-3">Add Product</div>
            <form asp-action="CreateProduct" method="post" class="form-grid">
                <input asp-for="Sku" class="form-control" placeholder="SKU" />
                <input asp-for="Name" class="form-control" placeholder="Name" />
                <input asp-for="Brand" class="form-control" placeholder="Brand" />
                <select asp-for="CategoryId" class="form-select">
                    <option value="">Uncategorized</option>
                    @foreach (var category in Model.Categories.Where(x => x.IsActive))
                    {
                        <option value="@category.Id">@category.Name (@category.Code)</option>
                    }
                </select>
                <textarea asp-for="Description" class="form-control" placeholder="Description"></textarea>
                <button class="btn btn-dark">Save Product</button>
            </form>
        </div>
    </div>
    <div class="col-lg-8">
        <div class="panel-card p-4">
            <table class="table align-middle">
                <thead>
                    <tr>
                        <th>Product</th>
                        <th>Category</th>
                        <th>Description</th>
                        <th>QR Preview</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var item in Model.Products)
                {
                    <tr>
                        <td>
                            <div class="fw-semibold">@item.Name</div>
                            <div class="small text-muted">@item.Sku</div>
                        </td>
                        <td>@(item.CategoryName ?? "Uncategorized")</td>
                        <td>@item.Description</td>
                        <td>
                            @if (Model.QrCodes.TryGetValue(item.Id, out var qr))
                            {
                                <div class="qr-preview-card qr-preview-card-row">
                                    <img class="qr-preview-image qr-preview-image-compact" src="@Url.Action("DownloadQr", "Management", new { qrId = qr.Id })" alt="QR for product @item.Sku" loading="lazy" />
                                    <a class="btn btn-sm btn-outline-dark w-100" asp-action="DownloadQr" asp-controller="Management" asp-route-qrId="@qr.Id">Download QR</a>
                                </div>
                            }
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>
